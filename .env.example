# AEGIS runs without paid credentials.
AEGIS_ENV=development
# Secure default: listen only on this laptop. Change this only for an intentional deployment.
AEGIS_API_HOST=127.0.0.1
# Optional comma-separated origins for a separately hosted frontend. Same-origin requests need no entry.
# AEGIS_ALLOWED_ORIGINS=http://127.0.0.1:5173
# Only configure this when AEGIS is behind these exact reverse-proxy IP addresses.
# AEGIS_TRUSTED_PROXY_ADDRESSES=127.0.0.1
AEGIS_LIVE_FETCH=true
# Normal runtime is live-only. Test fixtures are never loaded unless this is explicitly true.
AEGIS_USE_FIXTURES=false
AEGIS_ENABLE_LOCAL_EMBEDDINGS=true
AEGIS_EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2
# Optional local text-to-JSON model for filling fields the deterministic extractor could not identify.
# It is disabled by default because the model is larger and may download on first use.
AEGIS_ENABLE_LOCAL_STRUCTURED_AI=false
AEGIS_STRUCTURED_MODEL=Xenova/flan-t5-small
# Optional extended official HTML sources (PIB Fact Check and initial SDMA adapters).
AEGIS_ENABLE_EXTENDED_SOURCES=false
# Optional documented X API v2 integration. Leave unset to keep social handles reference-only.
AEGIS_ENABLE_SOCIAL_API=false
# A bearer token is required to fetch posts through the official API; never commit it.
# AEGIS_X_BEARER_TOKEN=
# Local API protection and source-fetch tuning.
AEGIS_ANALYZE_RATE_WINDOW_MS=60000
AEGIS_ANALYZE_RATE_MAX=12
AEGIS_TRANSCRIPTION_MODEL=Xenova/whisper-tiny
AEGIS_TRANSCRIPTION_TIMEOUT_MS=120000

# Disable local AI embeddings to use deterministic lexical fallback only.
# AEGIS_ENABLE_LOCAL_EMBEDDINGS=false
